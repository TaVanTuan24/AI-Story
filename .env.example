NODE_ENV=development
APP_URL=http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017/ai-story
AI_PROVIDER=openai
AI_MAX_RETRIES=2
AI_REQUEST_TIMEOUT_MS=25000
AI_RETRY_BASE_DELAY_MS=400
AI_RETRY_MAX_DELAY_MS=4000
AI_STORY_SUPPRESS_AI_KEY_WARNING=false
MEMORY_SHORT_TERM_TURNS=6
MEMORY_SUMMARY_INTERVAL=4
MEMORY_ROLLING_SUMMARIES_MAX=3
MEMORY_CANON_FACTS_MAX=24
MEMORY_ENABLE_CONSISTENCY_CHECK=true
MEMORY_ENABLE_SCENE_REPAIR=true
MEMORY_MAX_REPAIR_ATTEMPTS=1
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_TTL_HOURS=168
AUTH_COOKIE_NAME=ai-story.session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
PASSWORD_BCRYPT_ROUNDS=12
PASSWORD_PEPPER=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=10
GENERATION_RATE_LIMIT_WINDOW_MS=60000
GENERATION_RATE_LIMIT_MAX_REQUESTS=12
GENERATION_MAX_CONCURRENT_PER_ACTOR=1
CUSTOM_INPUT_MODERATION_COOLDOWN_MS=300000
CUSTOM_INPUT_MAX_LENGTH=1000
REQUEST_BODY_MAX_BYTES=50000
LOG_LEVEL=info
ADMIN_EMAILS=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
